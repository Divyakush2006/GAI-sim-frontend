# ============================================================
# GovernAI Studio — Environment Variables Template
# Copy this file to .env and fill in your values.
# ALL services below have free tiers. Total cost: ₹0/month.
# ============================================================

# === Application ===
ENVIRONMENT=development
DEBUG=true
APP_VERSION=3.0.0

# === Database (Neon PostgreSQL — Free: 0.5GB, 190 compute-hrs/month) ===
DATABASE_URL=postgresql+asyncpg://user:pass@host/neondb?ssl=require

# === LLM Providers (All Free Tiers) ===
GEMINI_API_KEY=your-gemini-key-here
GEMINI_API_KEYS=key1,key2,key3
GROQ_API_KEY=your-groq-key-here
CEREBRAS_API_KEY=your-cerebras-key-here
SAMBANOVA_API_KEY=your-sambanova-key-here

# === Authentication ===
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# === Email (Resend — Free: 100 emails/day) ===
RESEND_API_KEY=your-resend-key-here
RESEND_FROM_EMAIL=auth@governai.studio
ALLOWED_EMAIL_DOMAINS=["gov.in", "nic.in", "governai.in", "gmail.com"]

# === GraphRAG ===
GRAPH_DATA_DIR=./graph_data
CORPUS_RAW_DIR=./corpus/raw
CORPUS_PROCESSED_DIR=./corpus/processed

# === Rate Limits ===
GEMINI_RPM=15
GROQ_RPM=30
CEREBRAS_RPM=30
SAMBANOVA_RPM=20

# === CORS ===
CORS_ORIGINS=["http://localhost:3000", "https://governai.vercel.app"]
